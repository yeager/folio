[Desktop Entry]
Type=Application
Name=Folio
Name[sv]=Folio
Comment=Modern e-book reader with TTS support
Comment[sv]=Modern e-boksläsare med TTS-stöd
Exec=folio %F
Icon=se.danielnylander.folio
